          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "title", "value": "Job title", "type": "text" },
                { "key": "salaryMin", "value": "1000", "type": "text" },
                { "key": "salaryMax", "value": "2000", "type": "text" },
                { "key": "technologies", "value": "Node.js, React", "type": "text" },
                { "key": "images", "type": "file", "src": [] }
              ]
            },
            "url": "http://localhost:5000/company/job/create"
