{
  "info": {
    "name": "Project-6 Backend APIs",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection for Project-6 Node/Express backend running at http://localhost:5000"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Auth - Check User",
          "request": {
            "method": "GET",
            "url": "http://localhost:5000/auth/check"
          }
        },
        {
          "name": "Auth - Check Company",
          "request": {
            "method": "GET",
            "url": "http://localhost:5000/auth/company-check"
          }
        },
        {
          "name": "Auth - Logout",
          "request": {
            "method": "GET",
            "url": "http://localhost:5000/auth/logout"
          }
        }
      ]
    },
    {
      "name": "User",
      "item": [
        {
          "name": "User - Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"User Name\",\n  \"email\": \"user@example.com\",\n  \"password\": \"123456\"\n}"
            },
            "url": "http://localhost:5000/user/register"
          }
        },
        {
          "name": "User - Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"123456\"\n}"
            },
            "url": "http://localhost:5000/user/login"
          }
        },
        {
          "name": "User - Forgot Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\"\n}"
            },
            "url": "http://localhost:5000/user/forgot-password"
          }
        },
        {
          "name": "User - Reset Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"otp\": \"123456\",\n  \"newPassword\": \"123456\"\n}"
            },
            "url": "http://localhost:5000/user/reset-password"
          }
        },
        {
          "name": "User - Update Profile (with avatar)",
          "request": {
            "method": "PATCH",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "fullName", "value": "User Name", "type": "text" },
                { "key": "avatar", "type": "file", "src": [] }
              ]
            },
            "url": "http://localhost:5000/user/profile"
          }
        },
        {
          "name": "User - Change Password",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"oldPassword\": \"123456\",\n  \"newPassword\": \"654321\"\n}"
            },
            "url": "http://localhost:5000/user/change-password"
          }
        },
        {
          "name": "User - List CV",
          "request": {
            "method": "GET",
            "url": "http://localhost:5000/user/cv/list?page=1"
          }
        }
