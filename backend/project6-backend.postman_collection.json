            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"{{cvId}}\",\n  \"status\": \"accepted\"\n}"
            },
            "url": "http://localhost:5000/company/cv/change-status"
          }
        },
        {
          "name": "Company - Delete CV",
          "request": {
            "method": "DELETE",
            "url": "http://localhost:5000/company/cv/delete/{{cvId}}"
