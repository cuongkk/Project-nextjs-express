          "name": "Company - Get Job Detail For Edit",
          "request": {
            "method": "GET",
            "url": "http://localhost:5000/company/job/edit/{{jobId}}"
          }
        },
        {
          "name": "Company - Edit Job",
          "request": {
            "method": "PATCH",
