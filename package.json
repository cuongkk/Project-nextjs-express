    "@emotion/styled": "^11.14.1",
    "nodemailer": "^8.0.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/nodemailer": "^7.0.11",
    "tailwindcss": "^4.2.2"
  }
}
